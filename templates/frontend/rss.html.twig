<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
    <channel>
    {# TODO site name #}
        <title>some where</title>
        <link>{{ web_root }}</link>
        {# TODO site desc #}
        <description>you </description>
        <language>en-us</language>
        {# TODO dynamic rss url #}
        <atom:link href="{{ web_root }}/rss" rel="self" type="application/rss+xml" />
        {% for article in articles %}
        <item>
            <title>{{ article.title }}</title>
            {# TODO check  #}
            <link>{{ web_root }}/{{ path('news_item', {slug: article.slug}) }}</link>
            <description>{{ article.snippet }}</description>
            <pubDate>{{ article.getPublishDatetime|datetime }}</pubDate>
            {# TODO confirm this is correct #}
            <guid isPermaLink="false">{{article.id}}</guid>
        </item>
        {% endfor %}
    </channel>
</rss>
