{% if tags is not empty %}
<section>
  {% for tag in tags %}

  {% if tag.active %}
    <a href="/{{ parent_path }}" class="active">{{ tag.name }}</a>
  {% else %}
    <a href="/{{ parent_path }}/tag/{{ tag.slug }}" class="active">{{ tag.name }}</a>
  {% endif %}

  {% endfor %}
</section>
{% endif %}

<section class="post-tiles">
 {% for article in pagination.results %}

  <div class="post-item">
    <div class="card-item__image">
      <a href="/{{ parent_path }}/{{ article.slug }}">
        {{ image_tag(article.image, {loading: 'lazy'}) }}
      </a>
    </div>

    <div class="card-item__inner">
      <div class="card-item__details">
        <p class="card-item__date">{{ article.getPublishDatetime|datetime }}</p>
        <h3 class="card-item__title"><a href="/{{ parent_path }}/{{ article.slug }}">{{ article.title }}</a></h3>
        <p class="card-item__author">By {{ article.author }}</p>
        <div class="card-item__copy card-item__clip">
          <p>{{ article.snippet}}</p>
        </div>
      </div>

      <div class="card-item__more"><a href="/{{ parent_path }}/{{ article.slug }}" class="btn">Read More</a></div>
    </div>
  </div>
  {% endfor %}
</section>

{{ bootstrap_pagination(pagination) }}
<small>{{ bootstrap_pagination_info(pagination) }}</small>
