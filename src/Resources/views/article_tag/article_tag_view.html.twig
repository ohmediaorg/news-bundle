{% extends '@OHMediaBackend/base.html.twig' %}

{% block meta_title %}{{ article_tag }} | Article Tags{% endblock %}

{% block breadcrumbs %}
{{ bootstrap_breadcrumbs(
  bootstrap_breadcrumb(bootstrap_icon('tag') ~ ' Article Tags', 'article_tag_index'),
  bootstrap_breadcrumb(article_tag),
) }}
{% endblock %}

{% block actions %}
<div class="btn-group btn-group-sm">
  {% if is_granted(attributes.edit, article_tag) %}
    <a class="btn btn-primary" href="{{ path('article_tag_edit', {id: article_tag.id}) }}">
      {{ bootstrap_icon('pen-fill') }}
      Edit
    </a>
  {% endif %}
  {% if is_granted(attributes.delete, article_tag) %}
    <a class="btn btn-danger" href="{{ path('article_tag_delete', {id: article_tag.id}) }}" data-confirm="Are you sure you want to delete this article tag? Clicking OK will take you to a verification step to delete this entry.">
      {{ bootstrap_icon('trash-fill') }}
      Delete
    </a>
  {% endif %}
</div>
{% endblock %}

{% block main %}
<div class="card">
  <div class="card-body">
    <h1 class="card-title h3">Article Tag</h1>

    {{ dump(article_tag) }}
  </div>
</div>
{% endblock %}
