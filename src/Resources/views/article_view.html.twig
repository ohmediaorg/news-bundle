{% extends '@OHMediaBackend/base.html.twig' %}

{% block meta_title %}{{ article }} | Articles{% endblock %}

{% block breadcrumbs %}
{{ bootstrap_breadcrumbs(
  bootstrap_breadcrumb(bootstrap_icon('newspaper') ~ ' Articles', 'article_index'),
  bootstrap_breadcrumb(article),
) }}
{% endblock %}

{% block actions %}
<div class="btn-group btn-group-sm">
  {% if is_granted(attributes.edit, article) %}
    <a class="btn btn-primary" href="{{ path('article_edit', {id: article.id}) }}">
      {{ bootstrap_icon('pen-fill') }}
      Edit
    </a>
  {% endif %}
  {% if is_granted(attributes.delete, article) %}
    <a class="btn btn-danger" href="{{ path('article_delete', {id: article.id}) }}" data-confirm="Are you sure you want to delete this article? Clicking OK will take you to a verification step to delete this entry.">
      {{ bootstrap_icon('trash-fill') }}
      Delete
    </a>
  {% endif %}
</div>
{% endblock %}

{% block main %}
<div class="card">
  <div class="card-body">
    <h1 class="card-title h3">Article</h1>

    {{ dump(article) }}
  </div>
</div>
{% endblock %}
